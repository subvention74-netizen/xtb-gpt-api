{
  "openapi": "3.1.0",
  "info": {
    "title": "XTB GPT Custom Action API",
    "version": "1.0.0",
    "description": "API pour vérifier la disponibilité XTB France, récupérer un prix, des bougies intraday et des news."
  },
  "servers": [
    {
      "url": "https://REMPLACE-MOI.onrender.com"
    }
  ],
  "paths": {
    "/check_xtb_instrument": {
      "get": {
        "operationId": "check_xtb_instrument",
        "summary": "Vérifie si l'instrument semble proposé sur XTB France",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Résultat de vérification"
          }
        }
      }
    },
    "/get_realtime_quote": {
      "get": {
        "operationId": "get_realtime_quote",
        "summary": "Renvoie le prix actuel",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Prix actuel"
          }
        }
      }
    },
    "/get_intraday_bars": {
      "get": {
        "operationId": "get_intraday_bars",
        "summary": "Renvoie les bougies intraday",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["1m", "5m", "1h"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bougies intraday"
          }
        }
      }
    },
    "/get_market_news": {
      "get": {
        "operationId": "get_market_news",
        "summary": "Renvoie les news récentes",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "News de marché"
          }
        }
      }
    }
  }
}
